{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "trpc-server-functions": ["../../dist/index.d.ts"],
      "trpc-server-functions/vite": ["../../dist/vite.d.ts"]
    },
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
